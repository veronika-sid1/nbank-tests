# DEPOSIT TESTS
### positive: user can deposit min 0.01

POST http://localhost:4111/api/v1/accounts/deposit
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==
Content-Type: application/json

{
  "id": 5,
  "balance": 0.01
}

### positive: user can deposit 4999

POST http://localhost:4111/api/v1/accounts/deposit
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==
Content-Type: application/json

{
  "id": 5,
  "balance": 4999
}

### positive: user can deposit max 5000

POST http://localhost:4111/api/v1/accounts/deposit
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==
Content-Type: application/json

{
  "id": 5,
  "balance": 5000
}

### negative: user cannot deposit more than 5000

POST http://localhost:4111/api/v1/accounts/deposit
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==
Content-Type: application/json

{
  "id": 5,
  "balance": 5001
}

### negative: user cannot deposit zero amount

POST http://localhost:4111/api/v1/accounts/deposit
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==
Content-Type: application/json

{
  "id": 5,
  "balance": 0
}

### negative: user cannot deposit negative amount

POST http://localhost:4111/api/v1/accounts/deposit
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==
Content-Type: application/json

{
  "id": 5,
  "balance": -2
}

### negative: user cannot deposit to non-existent account

POST http://localhost:4111/api/v1/accounts/deposit
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==
Content-Type: application/json

{
  "id": 100,
  "balance": 100
}

### negative: user cannot deposit to someone else's account

POST http://localhost:4111/api/v1/accounts/deposit
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==
Content-Type: application/json

{
  "id": 3,
  "balance": 100
}

### negative: unauthorized user cannot deposit

POST http://localhost:4111/api/v1/accounts/deposit
Content-Type: application/json

{
  "id": 5,
  "balance": 100
}

### negative: user with invalid auth cannot deposit

POST http://localhost:4111/api/v1/accounts/deposit
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ=1
Content-Type: application/json

{
  "id": 3,
  "balance": 100
}

#TRANSFER TESTS
### positive: user can transfer money between his accounts

POST http://localhost:4111/api/v1/accounts/transfer
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==
Content-Type: application/json

{
  "senderAccountId": 5,
  "receiverAccountId": 4,
  "amount": 9999
}

### positive: user can transfer money to someone else's account

POST http://localhost:4111/api/v1/accounts/transfer
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==
Content-Type: application/json

{
  "senderAccountId": 5,
  "receiverAccountId": 6,
  "amount": 100
}

### positive: user can transfer max 10000

POST http://localhost:4111/api/v1/accounts/transfer
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==
Content-Type: application/json

{
  "senderAccountId": 4,
  "receiverAccountId": 5,
  "amount": 10000
}

### positive: user can transfer min 0.01

POST http://localhost:4111/api/v1/accounts/transfer
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==
Content-Type: application/json

{
  "senderAccountId": 4,
  "receiverAccountId": 5,
  "amount": 0.01
}

### negative: user cannot transfer more than 10000

POST http://localhost:4111/api/v1/accounts/transfer
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==
Content-Type: application/json

{
  "senderAccountId": 4,
  "receiverAccountId": 5,
  "amount": 10001
}

### negative: user cannot transfer negative amount

POST http://localhost:4111/api/v1/accounts/transfer
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==
Content-Type: application/json

{
  "senderAccountId": 4,
  "receiverAccountId": 5,
  "amount": -100

# NAME TESTS
### positive: user can specify name

PUT http://localhost:4111/api/v1/customer/profile
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==
Content-Type: application/json

{
  "name": "Anna Ivanova"
}

### positive: user can edit name

PUT http://localhost:4111/api/v1/customer/profile
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==
Content-Type: application/json

{
  "name": "Anna Petrova"
}

### negative: user cannot enter one word for name

PUT http://localhost:4111/api/v1/customer/profile
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==
Content-Type: application/json

{
  "name": "Anna"
}

### negative: user cannot enter digits in name

PUT http://localhost:4111/api/v1/customer/profile
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==
Content-Type: application/json

{
  "name": "Anna Petrova1"
}

### negative: user cannot enter empty name

PUT http://localhost:4111/api/v1/customer/profile
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==
Content-Type: application/json

{
  "name": ""
}

### negative: user cannot enter two spaces in name

PUT http://localhost:4111/api/v1/customer/profile
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==
Content-Type: application/json

{
  "name": "Anna  Ivanova"
}

### negative: user cannot enter three words in name

PUT http://localhost:4111/api/v1/customer/profile
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==
Content-Type: application/json

{
  "name": "Anna Ivanova Pavlova"
}

### negative: user cannot enter special characters in name

PUT http://localhost:4111/api/v1/customer/profile
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==
Content-Type: application/json

{
  "name": "Anna№*@$ Ivanova"
}

### negative: unauthorized user cannot specify name

PUT http://localhost:4111/api/v1/customer/profile
Content-Type: application/json

{
  "name": "Anna Ivanova"
}

### negative: user with invalid auth cannot specify name

PUT http://localhost:4111/api/v1/customer/profile
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ=1
Content-Type: application/json

{
  "name": "Anna Ivanova"
}

# PROFILE TESTS
### positive: user can see money transactions

GET http://localhost:4111/api/v1/accounts/4/transactions
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==

### positive: user can see personal profile

GET http://localhost:4111/api/v1/customer/profile
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==

### positive: user can see his accounts

GET http://localhost:4111/api/v1/customer/accounts
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==

### negative: unauthorized user cannot see money transactions

GET http://localhost:4111/api/v1/accounts/4/transactions

### negative: user cannot see someone else's money transactions

GET http://localhost:4111/api/v1/accounts/6/transactions
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==

### negative: user cannot see non-existent money transactions

GET http://localhost:4111/api/v1/accounts/100/transactions
Authorization: Basic YW5uYTE5OTY6UGFzc3dvcmQxIQ==

### negative: unauthorized user cannot see personal profile

GET http://localhost:4111/api/v1/customer/profile

### negative: unauthorized user cannot see personal accounts

GET http://localhost:4111/api/v1/customer/accounts
